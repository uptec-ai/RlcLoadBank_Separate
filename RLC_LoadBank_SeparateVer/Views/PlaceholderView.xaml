<UserControl x:Class="RLC_LoadBank_SeparateVer.Views.PlaceholderView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#F4F7F9">
    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
        <TextBlock Text="{Binding Title}" FontSize="26" FontWeight="Bold"
                   Foreground="{StaticResource InkBrush}" HorizontalAlignment="Center"/>
        <TextBlock Text="{Binding Caption}" FontSize="14" Margin="0,10,0,0"
                   Foreground="{StaticResource SubInkBrush}" HorizontalAlignment="Center"/>
    </StackPanel>
</UserControl>
