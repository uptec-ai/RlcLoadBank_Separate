<UserControl x:Class="RLC_LoadBank_SeparateVer.Views.OperationHistoryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:RLC_LoadBank_SeparateVer.ViewModels"
             Background="#F4F7F9" FontFamily="Malgun Gothic">
    <UserControl.DataContext>
        <vm:OperationHistoryViewModel/>
    </UserControl.DataContext>

    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="2,0,2,12">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="운전 이력" FontSize="20" FontWeight="Bold" Foreground="{StaticResource HeaderText}"/>
                <TextBlock Text="{Binding SourceText, StringFormat='저장소: {0}'}" FontSize="12" Foreground="{StaticResource SubInkBrush}" VerticalAlignment="Center" Margin="14,4,0,0"/>
                <TextBlock Text="{Binding Count, StringFormat='· {0} 건'}" FontSize="12" Foreground="{StaticResource SubInkBrush}" VerticalAlignment="Center" Margin="8,4,0,0"/>
            </StackPanel>
            <Button Content="↻ 새로고침" HorizontalAlignment="Right" Height="32" Padding="14,0" Command="{Binding RefreshCommand}"/>
        </Grid>

        <Border Grid.Row="1" Style="{StaticResource Card}">
            <DataGrid ItemsSource="{Binding Rows}" AutoGenerateColumns="False" IsReadOnly="True"
                      HeadersVisibility="Column" GridLinesVisibility="Horizontal" BorderThickness="0"
                      RowHeight="30" FontSize="12.5" Background="Transparent" RowBackground="Transparent" CanUserAddRows="False">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="시간" Binding="{Binding TimeText}" Width="180"/>
                    <DataGridTextColumn Header="판넬" Binding="{Binding Panel}" Width="100"/>
                    <DataGridTextColumn Header="이벤트 내용" Binding="{Binding Event}" Width="150"/>
                    <DataGridTemplateColumn Header="결과" Width="80">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Border CornerRadius="5" Padding="8,2" HorizontalAlignment="Left" Background="#EAF7F0">
                                    <TextBlock Text="{Binding Result}" Foreground="#27A86A" FontSize="11" FontWeight="SemiBold"/>
                                </Border>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</UserControl>
