<UserControl x:Class="RLC_LoadBank_SeparateVer.Views.DeviceConnectionView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:RLC_LoadBank_SeparateVer.ViewModels"
             xmlns:dxg="http://schemas.devexpress.com/winfx/2008/xaml/grid"
             xmlns:dxe="http://schemas.devexpress.com/winfx/2008/xaml/editors"
             Background="#F4F7F9" FontFamily="Segoe UI">
    <!-- DataContext (DeviceConnectionViewModel) is provided by the hosting window. -->

    <UserControl.Resources>
        <Style x:Key="Btn" TargetType="Button">
            <Setter Property="Height" Value="38"/>
            <Setter Property="Padding" Value="16,0"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource InkBrush}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="b" CornerRadius="8" Background="{TemplateBinding Background}" BorderBrush="{StaticResource CardBorder}" BorderThickness="1" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="b" Property="Background" Value="#EEF1F6"/></Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="BtnPrimary" TargetType="Button" BasedOn="{StaticResource Btn}">
            <Setter Property="Background" Value="#2F6FE0"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>
        <Style x:Key="MiniBtn" TargetType="Button" BasedOn="{StaticResource Btn}">
            <Setter Property="Height" Value="26"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="FontWeight" Value="Normal"/>
            <Setter Property="FontSize" Value="11"/>
        </Style>
        <Style x:Key="Lbl" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="{StaticResource SubInkBrush}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
    </UserControl.Resources>

    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>   <!-- header -->
            <RowDefinition Height="Auto"/>   <!-- summary -->
            <RowDefinition Height="*"/>      <!-- main -->
            <RowDefinition Height="Auto"/>   <!-- buttons -->
        </Grid.RowDefinitions>

        <!-- header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,14">
            <TextBlock Text="장비 연결 설정" FontSize="22" FontWeight="Bold" Foreground="{StaticResource HeaderText}"/>
            <TextBlock Text="PLC / ISEM / GIMAC Modbus TCP 연결 설정" FontSize="12" Foreground="{StaticResource SubInkBrush}" Margin="0,2,0,0"/>
        </StackPanel>

        <!-- ===== summary cards ===== -->
        <Grid Grid.Row="1" Margin="0,0,0,14">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.4*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- PLC comm -->
            <Border Grid.Column="0" Style="{StaticResource Card}" Margin="0,0,8,0">
                <Grid>
                    <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
                    <Grid Grid.Row="0" Margin="0,0,0,8">
                        <TextBlock Text="🖧  PLC 통신" Style="{StaticResource SectionHeader}"/>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <Ellipse Width="9" Height="9" Fill="#27A86A" VerticalAlignment="Center" Margin="0,0,5,0"/>
                            <TextBlock Text="{Binding PlcSummary}" FontSize="12" Foreground="{StaticResource SubInkBrush}"/>
                        </StackPanel>
                    </Grid>
                    <!-- header row -->
                    <Grid Grid.Row="1" Margin="0,0,0,2">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="1.3*"/><ColumnDefinition Width="1.3*"/><ColumnDefinition Width="0.6*"/><ColumnDefinition Width="0.7*"/><ColumnDefinition Width="0.8*"/><ColumnDefinition Width="0.9*"/></Grid.ColumnDefinitions>
                        <TextBlock Text="이름" Style="{StaticResource Lbl}" FontWeight="SemiBold"/>
                        <TextBlock Grid.Column="1" Text="IP 주소" Style="{StaticResource Lbl}" FontWeight="SemiBold"/>
                        <TextBlock Grid.Column="2" Text="Port" Style="{StaticResource Lbl}" FontWeight="SemiBold"/>
                        <TextBlock Grid.Column="3" Text="Unit ID" Style="{StaticResource Lbl}" FontWeight="SemiBold"/>
                        <TextBlock Grid.Column="4" Text="상태" Style="{StaticResource Lbl}" FontWeight="SemiBold"/>
                        <TextBlock Grid.Column="5" Text="연결" Style="{StaticResource Lbl}" FontWeight="SemiBold"/>
                    </Grid>
                    <ItemsControl Grid.Row="2" ItemsSource="{Binding Plcs}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,4">
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="1.3*"/><ColumnDefinition Width="1.3*"/><ColumnDefinition Width="0.6*"/><ColumnDefinition Width="0.7*"/><ColumnDefinition Width="0.8*"/><ColumnDefinition Width="0.9*"/></Grid.ColumnDefinitions>
                                    <TextBlock Text="{Binding Name}" Style="{StaticResource Lbl}" Foreground="{StaticResource InkBrush}" FontWeight="SemiBold"/>
                                    <TextBlock Grid.Column="1" Text="{Binding Ip}" Style="{StaticResource Lbl}"/>
                                    <TextBlock Grid.Column="2" Text="{Binding Port}" Style="{StaticResource Lbl}"/>
                                    <TextBlock Grid.Column="3" Text="{Binding UnitId}" Style="{StaticResource Lbl}"/>
                                    <Border Grid.Column="4" CornerRadius="5" Padding="7,2" HorizontalAlignment="Left" VerticalAlignment="Center"
                                            Background="{Binding State, Converter={StaticResource ConnBrush}}">
                                        <TextBlock Text="{Binding StatusText}" Foreground="White" FontSize="10" FontWeight="SemiBold"/>
                                    </Border>
                                    <Button Grid.Column="5" Content="Disconnect" Style="{StaticResource MiniBtn}" HorizontalAlignment="Left"
                                            Command="{Binding DataContext.DisconnectDeviceCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                            CommandParameter="{Binding}"/>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Grid>
            </Border>

            <!-- metering -->
            <Border Grid.Column="1" Style="{StaticResource Card}" Margin="8,0,8,0">
                <StackPanel>
                    <TextBlock Text="📈  계측 장비" Style="{StaticResource SectionHeader}" Margin="0,0,0,10"/>
                    <Border Background="#F7F9FC" CornerRadius="8" Padding="12,10" Margin="0,0,0,8">
                        <Grid>
                            <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="ISEM (전력 모니터)" FontWeight="SemiBold" FontSize="12" Foreground="{StaticResource InkBrush}"/>
                                <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                    <TextBlock Text="{Binding IsemTotal}" FontSize="22" FontWeight="Bold" Foreground="{StaticResource BlueBrush}"/>
                                    <TextBlock Text="대" VerticalAlignment="Bottom" Margin="3,0,0,3" Foreground="{StaticResource SubInkBrush}"/>
                                </StackPanel>
                            </StackPanel>
                            <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                <StackPanel Orientation="Horizontal"><TextBlock Text="연결됨 " Style="{StaticResource Lbl}"/><TextBlock Text="{Binding IsemConnected}" Foreground="#27A86A" FontWeight="SemiBold"/><TextBlock Text="대" Foreground="#27A86A"/></StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,3,0,0"><TextBlock Text="미연결 " Style="{StaticResource Lbl}"/><TextBlock Text="{Binding IsemDisconnected}" Foreground="{StaticResource OrangeBrush}" FontWeight="SemiBold"/><TextBlock Text="대" Foreground="{StaticResource OrangeBrush}"/></StackPanel>
                            </StackPanel>
                        </Grid>
                    </Border>
                    <Border Background="#F7F9FC" CornerRadius="8" Padding="12,10">
                        <Grid>
                            <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="GIMAC (전력 제어기)" FontWeight="SemiBold" FontSize="12" Foreground="{StaticResource InkBrush}"/>
                                <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                    <TextBlock Text="{Binding GimacTotal}" FontSize="22" FontWeight="Bold" Foreground="{StaticResource BlueBrush}"/>
                                    <TextBlock Text="대" VerticalAlignment="Bottom" Margin="3,0,0,3" Foreground="{StaticResource SubInkBrush}"/>
                                </StackPanel>
                            </StackPanel>
                            <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                <StackPanel Orientation="Horizontal"><TextBlock Text="연결됨 " Style="{StaticResource Lbl}"/><TextBlock Text="{Binding GimacConnected}" Foreground="#27A86A" FontWeight="SemiBold"/><TextBlock Text="대" Foreground="#27A86A"/></StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,3,0,0"><TextBlock Text="미연결 " Style="{StaticResource Lbl}"/><TextBlock Text="{Binding GimacDisconnected}" Foreground="{StaticResource OrangeBrush}" FontWeight="SemiBold"/><TextBlock Text="대" Foreground="{StaticResource OrangeBrush}"/></StackPanel>
                            </StackPanel>
                        </Grid>
                    </Border>
                </StackPanel>
            </Border>

            <!-- server (placeholder) -->
            <Border Grid.Column="2" Style="{StaticResource Card}" Margin="8,0,0,0">
                <StackPanel>
                    <TextBlock Text="🖥  Monitoring Server" Style="{StaticResource SectionHeader}" Margin="0,0,0,10"/>
                    <Grid>
                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Margin="0,0,8,0">
                            <TextBlock Text="IP 주소" Style="{StaticResource Lbl}"/>
                            <TextBox Text="{Binding ServerIp}" Height="30" Margin="0,3,0,0" VerticalContentAlignment="Center" Padding="6,0"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Margin="0,0,8,0" Width="70">
                            <TextBlock Text="Port" Style="{StaticResource Lbl}"/>
                            <TextBox Text="{Binding ServerPort}" Height="30" Margin="0,3,0,0" VerticalContentAlignment="Center" Padding="6,0"/>
                        </StackPanel>
                        <Button Grid.Column="2" Content="Apply Server" Style="{StaticResource Btn}" VerticalAlignment="Bottom" Command="{Binding ApplyServerCommand}"/>
                    </Grid>
                    <TextBlock Text="상태" Style="{StaticResource Lbl}" Margin="0,10,0,3"/>
                    <StackPanel Orientation="Horizontal">
                        <Border CornerRadius="6" Background="#EAF7F0" Padding="12,5">
                            <StackPanel Orientation="Horizontal">
                                <Ellipse Width="8" Height="8" Fill="#27A86A" VerticalAlignment="Center" Margin="0,0,5,0"/>
                                <TextBlock Text="{Binding ServerStateText}" FontSize="12" Foreground="#27A86A" FontWeight="SemiBold"/>
                            </StackPanel>
                        </Border>
                        <TextBlock Text="{Binding ServerClients, StringFormat=' / Clients {0}'}" Style="{StaticResource Lbl}" Margin="8,0,0,0"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>

        <!-- ===== main: tabs + detail ===== -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="320"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource Card}" Padding="6" Margin="0,0,8,0">
                <TabControl BorderThickness="0" Background="Transparent">
                    <TabItem Header="PLC" Width="60">
                        <TabItem.Style>
                            <Style TargetType="TabItem">
                                <Style.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter Property="Foreground" Value="#FF2F84E7"/>
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                        <Setter Property="BorderThickness" Value="0"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </TabItem.Style>
                        <dxg:GridControl ItemsSource="{Binding Plcs}" SelectedItem="{Binding SelectedDevice}" AutoGenerateColumns="None" ShowBorder="True">
                            <dxg:GridControl.Columns>
                                <dxg:GridColumn FieldName="Use" Header="Use" Width="46"/>
                                <dxg:GridColumn FieldName="Type" Header="Type" ReadOnly="True" Width="60"/>
                                <dxg:GridColumn FieldName="Name" Header="이름" Width="130"/>
                                <dxg:GridColumn FieldName="Ip" Header="IP 주소" Width="120"/>
                                <dxg:GridColumn FieldName="Port" Header="Port" Width="60"/>
                                <dxg:GridColumn FieldName="UnitId" Header="Unit ID" Width="64"/>
                                <dxg:GridColumn FieldName="SlaveId" Header="Slave ID" Width="64"/>
                                <dxg:GridColumn FieldName="CurrentReg" Header="Current Reg" Width="80"/>
                                <dxg:GridColumn FieldName="Scale" Header="Scale" Width="56"/>
                                <dxg:GridColumn FieldName="InputReg" Header="Input Reg" Width="72"/>
                                <dxg:GridColumn FieldName="Current" Header="Current" ReadOnly="True" Width="60"/>
                                <dxg:GridColumn FieldName="StatusText" Header="상태" ReadOnly="True" Width="70"/>
                                <dxg:GridColumn FieldName="LastSeenShort" Header="Last Seen" ReadOnly="True" Width="80"/>
                            </dxg:GridControl.Columns>
                            <dxg:GridControl.View>
                                <dxg:TableView ShowGroupPanel="False" ShowIndicator="False" AllowEditing="True" NavigationStyle="Cell" AlternateRowBackground="#F7F9FC"/>
                            </dxg:GridControl.View>
                        </dxg:GridControl>
                    </TabItem>
                    <TabItem Header="ISEM">
                        <dxg:GridControl ItemsSource="{Binding Isems}" SelectedItem="{Binding SelectedDevice}" AutoGenerateColumns="None">
                            <dxg:GridControl.Columns>
                                <dxg:GridColumn FieldName="Use" Header="Use" Width="46"/>
                                <dxg:GridColumn FieldName="Type" Header="Type" ReadOnly="True" Width="60"/>
                                <dxg:GridColumn FieldName="Name" Header="이름" Width="150"/>
                                <dxg:GridColumn FieldName="Ip" Header="IP 주소" Width="120"/>
                                <dxg:GridColumn FieldName="Port" Header="Port" Width="60"/>
                                <dxg:GridColumn FieldName="UnitId" Header="Unit ID" Width="64"/>
                                <dxg:GridColumn FieldName="SlaveId" Header="Slave ID" Width="64"/>
                                <dxg:GridColumn FieldName="CurrentReg" Header="Current Reg" Width="80"/>
                                <dxg:GridColumn FieldName="Scale" Header="Scale" Width="56"/>
                                <dxg:GridColumn FieldName="InputReg" Header="Input Reg" Width="72"/>
                                <dxg:GridColumn FieldName="StatusText" Header="상태" ReadOnly="True" Width="70"/>
                                <dxg:GridColumn FieldName="LastSeenShort" Header="Last Seen" ReadOnly="True" Width="80"/>
                            </dxg:GridControl.Columns>
                            <dxg:GridControl.View>
                                <dxg:TableView ShowGroupPanel="False" ShowIndicator="False" AllowEditing="True" NavigationStyle="Cell" AlternateRowBackground="#F7F9FC"/>
                            </dxg:GridControl.View>
                        </dxg:GridControl>
                    </TabItem>
                    <TabItem Header="GIMAC">
                        <dxg:GridControl ItemsSource="{Binding Gimacs}" SelectedItem="{Binding SelectedDevice}" AutoGenerateColumns="None">
                            <dxg:GridControl.Columns>
                                <dxg:GridColumn FieldName="Use" Header="Use" Width="46"/>
                                <dxg:GridColumn FieldName="Type" Header="Type" ReadOnly="True" Width="60"/>
                                <dxg:GridColumn FieldName="Name" Header="이름" Width="150"/>
                                <dxg:GridColumn FieldName="Ip" Header="IP 주소" Width="120"/>
                                <dxg:GridColumn FieldName="Port" Header="Port" Width="60"/>
                                <dxg:GridColumn FieldName="UnitId" Header="Unit ID" Width="64"/>
                                <dxg:GridColumn FieldName="SlaveId" Header="Slave ID" Width="64"/>
                                <dxg:GridColumn FieldName="CurrentReg" Header="Current Reg" Width="80"/>
                                <dxg:GridColumn FieldName="Scale" Header="Scale" Width="56"/>
                                <dxg:GridColumn FieldName="InputReg" Header="Input Reg" Width="72"/>
                                <dxg:GridColumn FieldName="StatusText" Header="상태" ReadOnly="True" Width="70"/>
                                <dxg:GridColumn FieldName="LastSeenShort" Header="Last Seen" ReadOnly="True" Width="80"/>
                            </dxg:GridControl.Columns>
                            <dxg:GridControl.View>
                                <dxg:TableView ShowGroupPanel="False" ShowIndicator="False" AllowEditing="True" NavigationStyle="Cell" AlternateRowBackground="#F7F9FC"/>
                            </dxg:GridControl.View>
                        </dxg:GridControl>
                    </TabItem>
                    <TabItem Header="Server">
                        <Grid>
                            <dxg:GridControl ItemsSource="{Binding Servers}" SelectedItem="{Binding SelectedDevice}" AutoGenerateColumns="None">
                                <dxg:GridControl.Columns>
                                    <dxg:GridColumn FieldName="Name" Header="이름" Width="160"/>
                                    <dxg:GridColumn FieldName="Ip" Header="IP 주소" Width="140"/>
                                    <dxg:GridColumn FieldName="Port" Header="Port" Width="70"/>
                                    <dxg:GridColumn FieldName="StatusText" Header="상태" ReadOnly="True" Width="90"/>
                                </dxg:GridControl.Columns>
                                <dxg:GridControl.View><dxg:TableView ShowGroupPanel="False" ShowIndicator="False"/></dxg:GridControl.View>
                            </dxg:GridControl>
                            <TextBlock Text="추후 사용 — 현재 비활성 (기능 off)" HorizontalAlignment="Center" VerticalAlignment="Center"
                                       Foreground="{StaticResource GreyBrush}" FontSize="13"/>
                        </Grid>
                    </TabItem>
                </TabControl>
            </Border>

            <!-- detail -->
            <Border Grid.Column="1" Style="{StaticResource Card}" Margin="8,0,0,0">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel DataContext="{Binding SelectedDevice}">
                        <TextBlock Text="선택 장비 상세" Style="{StaticResource SectionHeader}" Margin="0,0,0,12"/>
                        <Grid Margin="0,0,0,8"><Grid.ColumnDefinitions><ColumnDefinition Width="80"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                            <TextBlock Text="Type" Style="{StaticResource Lbl}"/>
                            <TextBox Grid.Column="1" Text="{Binding Type, Mode=OneWay}" IsReadOnly="True" Height="30" VerticalContentAlignment="Center" Padding="6,0"/>
                        </Grid>
                        <Grid Margin="0,0,0,8"><Grid.ColumnDefinitions><ColumnDefinition Width="80"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                            <TextBlock Text="이름" Style="{StaticResource Lbl}"/>
                            <TextBox Grid.Column="1" Text="{Binding Name}" Height="30" VerticalContentAlignment="Center" Padding="6,0"/>
                        </Grid>
                        <Grid Margin="0,0,0,8"><Grid.ColumnDefinitions><ColumnDefinition Width="80"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                            <TextBlock Text="IP 주소" Style="{StaticResource Lbl}"/>
                            <TextBox Grid.Column="1" Text="{Binding Ip}" Height="30" VerticalContentAlignment="Center" Padding="6,0"/>
                        </Grid>
                        <Grid Margin="0,0,0,8"><Grid.ColumnDefinitions><ColumnDefinition Width="80"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                            <TextBlock Text="Port" Style="{StaticResource Lbl}"/>
                            <TextBox Grid.Column="1" Text="{Binding Port}" Height="30" VerticalContentAlignment="Center" Padding="6,0"/>
                        </Grid>
                        <Grid Margin="0,0,0,8"><Grid.ColumnDefinitions><ColumnDefinition Width="80"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                            <TextBlock Text="Unit ID" Style="{StaticResource Lbl}"/>
                            <TextBox Grid.Column="1" Text="{Binding UnitId}" Height="30" VerticalContentAlignment="Center" Padding="6,0"/>
                        </Grid>
                        <Grid Margin="0,0,0,8"><Grid.ColumnDefinitions><ColumnDefinition Width="80"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                            <TextBlock Text="Slave ID" Style="{StaticResource Lbl}"/>
                            <TextBox Grid.Column="1" Text="{Binding SlaveId}" Height="30" VerticalContentAlignment="Center" Padding="6,0"/>
                        </Grid>
                        <Grid Margin="0,0,0,8"><Grid.ColumnDefinitions><ColumnDefinition Width="80"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <TextBlock Text="Poll Interval" Style="{StaticResource Lbl}"/>
                            <TextBox Grid.Column="1" Text="{Binding PollInterval}" Height="30" VerticalContentAlignment="Center" Padding="6,0"/>
                            <TextBlock Grid.Column="2" Text="ms" Style="{StaticResource Lbl}" Margin="6,0,0,0"/>
                        </Grid>
                        <Grid Margin="0,0,0,12"><Grid.ColumnDefinitions><ColumnDefinition Width="80"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <TextBlock Text="Timeout" Style="{StaticResource Lbl}"/>
                            <TextBox Grid.Column="1" Text="{Binding Timeout}" Height="30" VerticalContentAlignment="Center" Padding="6,0"/>
                            <TextBlock Grid.Column="2" Text="ms" Style="{StaticResource Lbl}" Margin="6,0,0,0"/>
                        </Grid>

                        <Button Content="🔗  연결 테스트" Style="{StaticResource Btn}" Margin="0,0,0,12"
                                Command="{Binding DataContext.TestConnectionCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"/>

                        <Border Background="#F7F9FC" CornerRadius="8" Padding="12">
                            <StackPanel>
                                <Grid Margin="0,0,0,6"><Grid.ColumnDefinitions><ColumnDefinition Width="80"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                    <TextBlock Text="상태" Style="{StaticResource Lbl}"/>
                                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                                        <Ellipse Width="9" Height="9" VerticalAlignment="Center" Margin="0,0,5,0" Fill="{Binding State, Converter={StaticResource ConnBrush}}"/>
                                        <TextBlock Text="{Binding StatusText}" FontSize="12" Foreground="{StaticResource InkBrush}"/>
                                    </StackPanel>
                                </Grid>
                                <Grid Margin="0,0,0,6"><Grid.ColumnDefinitions><ColumnDefinition Width="80"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                    <TextBlock Text="Last Seen" Style="{StaticResource Lbl}"/>
                                    <TextBlock Grid.Column="1" Text="{Binding LastSeenText}" Style="{StaticResource Lbl}" Foreground="{StaticResource InkBrush}"/>
                                </Grid>
                                <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="80"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                    <TextBlock Text="Last Error" Style="{StaticResource Lbl}"/>
                                    <TextBlock Grid.Column="1" Text="{Binding LastError}" Style="{StaticResource Lbl}" Foreground="{StaticResource InkBrush}" TextWrapping="Wrap"/>
                                </Grid>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>

        <!-- ===== bottom buttons ===== -->
        <Grid Grid.Row="3" Margin="0,14,0,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                <Button Content="🔌  선택 장비 연결" Style="{StaticResource Btn}" Margin="0,0,8,0" Command="{Binding ConnectSelectedCommand}"/>
                <Button Content="⊘  선택 장비 해제" Style="{StaticResource Btn}" Margin="0,0,8,0" Command="{Binding DisconnectSelectedCommand}"/>
                <Button Content="⤴  전체 적용" Style="{StaticResource Btn}" Command="{Binding ApplyAllCommand}"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="💾  저장" Style="{StaticResource BtnPrimary}" Width="120" Margin="0,0,8,0" Command="{Binding SaveCommand}"/>
                <Button Content="닫기" Style="{StaticResource Btn}" Width="100" Command="{Binding CloseCommand}"/>
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>
