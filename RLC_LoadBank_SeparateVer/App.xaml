<Application x:Class="RLC_LoadBank_SeparateVer.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:core="clr-namespace:RLC_LoadBank_SeparateVer.Core"
             xmlns:vm="clr-namespace:RLC_LoadBank_SeparateVer.ViewModels"
             xmlns:views="clr-namespace:RLC_LoadBank_SeparateVer.Views"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <ResourceDictionary>

            <!-- Converters -->
            <core:McStateToBrushConverter x:Key="McBrush"/>
            <core:ConnStateToBrushConverter x:Key="ConnBrush"/>
            <core:AlarmLevelToBrushConverter x:Key="AlarmBrush"/>
            <core:BoolToVisibilityConverter x:Key="BoolVis"/>
            <core:EnumEqualsConverter x:Key="EnumEq"/>
            <core:BoolToBgBrushConverter x:Key="BoolToBgBrush"/>
            <core:BoolToTextConverter x:Key="BoolToTextConverter"/>

            <!-- Palette -->
            <SolidColorBrush x:Key="InkBrush" Color="#2D333F"/>
            <SolidColorBrush x:Key="SubInkBrush" Color="#5B6472"/>
            <SolidColorBrush x:Key="GreenBrush" Color="#27A86A"/>
            <SolidColorBrush x:Key="OrangeBrush" Color="#E8943A"/>
            <SolidColorBrush x:Key="RedBrush" Color="#E04F4F"/>
            <SolidColorBrush x:Key="GreyBrush" Color="#ADB4BF"/>
            <SolidColorBrush x:Key="BlueBrush" Color="#2F6FE0"/>
            <SolidColorBrush x:Key="CardBg" Color="#FFFFFF"/>
            <SolidColorBrush x:Key="CardBorder" Color="#E3E7ED"/>
            <SolidColorBrush x:Key="RailBg" Color="#F5F7FA"/>
            <SolidColorBrush x:Key="HeaderText" Color="#2F6FE0"/>

            <!-- VM -> View -->
            <DataTemplate DataType="{x:Type vm:RlcStatusViewModel}">
                <views:RlcStatusView/>
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:PlaceholderViewModel}">
                <views:PlaceholderView/>
            </DataTemplate>

            <!-- Card border -->
            <Style x:Key="Card" TargetType="Border">
                <Setter Property="Background" Value="{StaticResource CardBg}"/>
                <Setter Property="BorderBrush" Value="{StaticResource CardBorder}"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="CornerRadius" Value="10"/>
                <Setter Property="Padding" Value="14"/>
            </Style>

            <!-- Section header text -->
            <Style x:Key="SectionHeader" TargetType="TextBlock">
                <Setter Property="Foreground" Value="{StaticResource HeaderText}"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="FontSize" Value="14"/>
            </Style>

            <!-- MC circle button (diagram) -->
            <Style x:Key="McCircle" TargetType="Button">
                <Setter Property="Width" Value="34"/>
                <Setter Property="Margin" Value="2"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="Command" Value="{Binding ToggleCommand}"/>
                <Setter Property="ToolTip" Value="{Binding Tag}"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <StackPanel HorizontalAlignment="Center">
                                <Grid Width="26" Height="26" HorizontalAlignment="Center">
                                    <Ellipse x:Name="ring" Fill="White"
                                             Stroke="{Binding State, Converter={StaticResource McBrush}}"
                                             StrokeThickness="2.5"/>
                                    <TextBlock Text="{Binding Label}" FontSize="10"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"
                                               Foreground="{StaticResource InkBrush}"/>
                                </Grid>
                                <TextBlock Text="{Binding ValueText}" FontSize="10"
                                           HorizontalAlignment="Center"
                                           Foreground="{StaticResource SubInkBrush}"
                                           Margin="0,1,0,0"/>
                            </StackPanel>
                            <ControlTemplate.Triggers>
                                <DataTrigger Binding="{Binding State}" Value="On">
                                    <Setter TargetName="ring" Property="Fill" Value="#E4F5EC"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding State}" Value="CommWait">
                                    <Setter TargetName="ring" Property="Fill" Value="#FBEEDD"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding State}" Value="Trip">
                                    <Setter TargetName="ring" Property="Fill" Value="#FBE3E3"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding State}" Value="Alarm">
                                    <Setter TargetName="ring" Property="Fill" Value="#FBE3E3"/>
                                </DataTrigger>
                                <!-- 자동운전 계획 미리보기: Off 상태의 예정 MC를 주황 테두리/배경으로 표시 -->
                                <MultiDataTrigger>
                                    <MultiDataTrigger.Conditions>
                                        <Condition Binding="{Binding IsPlanned}" Value="True"/>
                                        <Condition Binding="{Binding State}" Value="Off"/>
                                    </MultiDataTrigger.Conditions>
                                    <Setter TargetName="ring" Property="Stroke" Value="#E8943A"/>
                                    <Setter TargetName="ring" Property="Fill" Value="#FBF0E5"/>
                                </MultiDataTrigger>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="ring" Property="StrokeThickness" Value="3.5"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- C-stage block: IsRunning(동작), HasAlarm(알람), MC1/SCR/MC2 알람 도트 -->
            <Style x:Key="CStageBlock" TargetType="Button">
                <Setter Property="Width" Value="44"/>
                <Setter Property="Margin" Value="2"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="Command" Value="{Binding ToggleCommand}"/>
                <Setter Property="ToolTip" Value="{Binding Label}"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <StackPanel HorizontalAlignment="Center">
                                <Grid Width="30" Height="30" HorizontalAlignment="Center">
                                    <Ellipse x:Name="ring" Fill="White" Stroke="#9E9E9E" StrokeThickness="2.5"/>
                                    <TextBlock Text="{Binding Label}" FontSize="10"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"
                                               Foreground="{StaticResource InkBrush}"/>
                                </Grid>
                                <!-- 알람 도트: MC1 · SCR · MC2 -->
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,2,0,0">
                                    <Ellipse x:Name="dotMc1" Width="7" Height="7" Margin="1,0" Fill="Transparent"/>
                                    <Ellipse x:Name="dotScr"  Width="7" Height="7" Margin="1,0" Fill="Transparent"/>
                                    <Ellipse x:Name="dotMc2" Width="7" Height="7" Margin="1,0" Fill="Transparent"/>
                                </StackPanel>
                            </StackPanel>
                            <ControlTemplate.Triggers>
                                <!-- 동작 중 -->
                                <DataTrigger Binding="{Binding IsRunning}" Value="True">
                                    <Setter TargetName="ring" Property="Fill"   Value="#E4F5EC"/>
                                    <Setter TargetName="ring" Property="Stroke" Value="#27A86A"/>
                                </DataTrigger>
                                <!-- 알람 발생 -->
                                <DataTrigger Binding="{Binding HasAlarm}" Value="True">
                                    <Setter TargetName="ring" Property="Fill"   Value="#FBE3E3"/>
                                    <Setter TargetName="ring" Property="Stroke" Value="#E53935"/>
                                </DataTrigger>
                                <!-- 개별 알람 도트 -->
                                <DataTrigger Binding="{Binding Mc1Alarm}" Value="True">
                                    <Setter TargetName="dotMc1" Property="Fill" Value="#E53935"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding ScrAlarm}" Value="True">
                                    <Setter TargetName="dotScr" Property="Fill" Value="#E53935"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding Mc2Alarm}" Value="True">
                                    <Setter TargetName="dotMc2" Property="Fill" Value="#E53935"/>
                                </DataTrigger>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="ring" Property="StrokeThickness" Value="3.5"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- Load-group box header -->
            <Style x:Key="LoadBoxHeader" TargetType="TextBlock">
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="FontSize" Value="12"/>
                <Setter Property="Margin" Value="2,0,0,6"/>
            </Style>

        </ResourceDictionary>
    </Application.Resources>
</Application>
